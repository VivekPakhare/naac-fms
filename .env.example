# Environment Configuration
# Copy this file to server/.env and fill in your values

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/naac_db

# ── JWT Authentication ────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# ── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── File Uploads ──────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# ── Frontend URL (for CORS) ──────────────────────────
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ── Default HOD Account (used by seed script) ────────
HOD_EMAIL=hod@naac.edu
HOD_PASSWORD=HOD@2024

# ── Embedded PostgreSQL (dev only) ────────────────────
EMBEDDED_PG=true
PG_PORT=5432
