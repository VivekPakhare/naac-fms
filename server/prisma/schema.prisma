// ============================================================================
// NAAC File Management System — Prisma Schema
// ============================================================================
//
// Entity-Relationship Overview:
//
//   users ──1:N──▶ form_submissions ◀──N:1── sub_criteria ──N:1──▶ criteria
//   users ──1:N──▶ uploaded_documents ◀──N:1── sub_criteria
//                  uploaded_documents ──N:0..1──▶ form_submissions
//   users ──1:N──▶ activity_logs
//   users ──1:N──▶ notifications (as recipient)
//   users ──1:N──▶ notifications (as sender)
//
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp")]
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  teacher
  hod

  @@map("user_role")
}

enum SubmissionStatus {
  draft
  submitted
  verified
  needs_revision

  @@map("submission_status")
}

enum UploadStatus {
  pending
  uploaded
  verified

  @@map("upload_status")
}

enum NotificationType {
  reminder
  revision_request
  verified
  deadline

  @@map("notification_type")
}

// ── Models ───────────────────────────────────────────────────────────────────

/// Registered users — teachers and HODs (super users).
model User {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  fullName       String   @map("full_name") @db.VarChar(255)
  email          String   @unique @db.VarChar(255)
  passwordHash   String   @map("password_hash") @db.VarChar(255)
  role           UserRole @default(teacher)
  department     String?  @db.VarChar(255)
  designation    String?  @db.VarChar(255)
  subjectsTaught String?  @map("subjects_taught") @db.Text
  isActive       Boolean  @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at") @db.Timestamptz
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  formSubmissions   FormSubmission[]
  uploadedDocuments UploadedDocument[]
  activityLogs      ActivityLog[]
  receivedNotifs    Notification[]     @relation("NotifRecipient")
  sentNotifs        Notification[]     @relation("NotifSender")

  @@index([email], map: "idx_users_email")
  @@index([role], map: "idx_users_role")
  @@index([department], map: "idx_users_department")
  @@map("users")
}

/// 7 NAAC Criteria (seed data).
model Criterion {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(10) // e.g. 'C1'
  name      String   @db.VarChar(255)
  maxMarks  Int      @default(0) @map("max_marks")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  subCriteria SubCriterion[]

  @@map("criteria")
}

/// Sub-criteria under each criterion (20 seed rows).
model SubCriterion {
  id          Int      @id @default(autoincrement())
  criteriaId  Int      @map("criteria_id")
  code        String   @unique @db.VarChar(10) // e.g. '1.1', '2.3'
  name        String   @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  criterion         Criterion          @relation(fields: [criteriaId], references: [id], onDelete: Cascade)
  formSubmissions   FormSubmission[]
  uploadedDocuments UploadedDocument[]

  @@index([criteriaId], map: "idx_sub_criteria_criteria_id")
  @@index([code], map: "idx_sub_criteria_code")
  @@map("sub_criteria")
}

/// Form submissions by teachers for each sub-criterion.
model FormSubmission {
  id            String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  teacherId     String           @map("teacher_id") @db.Uuid
  subCriteriaId Int              @map("sub_criteria_id")
  formData      Json             @default("{}") @map("form_data") @db.JsonB
  status        SubmissionStatus @default(draft)
  hodComment    String?          @map("hod_comment") @db.Text
  submittedAt   DateTime?        @map("submitted_at") @db.Timestamptz
  verifiedAt    DateTime?        @map("verified_at") @db.Timestamptz
  verifiedBy    String?          @map("verified_by") @db.Uuid
  updatedAt     DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  teacher      User               @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subCriterion SubCriterion       @relation(fields: [subCriteriaId], references: [id], onDelete: Cascade)
  documents    UploadedDocument[]

  // One submission per teacher per sub-criterion
  @@unique([teacherId, subCriteriaId], map: "uq_teacher_subcriteria")
  @@index([teacherId], map: "idx_form_sub_teacher")
  @@index([subCriteriaId], map: "idx_form_sub_subcriteria")
  @@index([status], map: "idx_form_sub_status")
  @@index([submittedAt], map: "idx_form_sub_submitted_at")
  @@map("form_submissions")
}

/// Files uploaded by teachers, linked to sub-criteria and optionally to a form submission.
model UploadedDocument {
  id               String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  teacherId        String       @map("teacher_id") @db.Uuid
  subCriteriaId    Int          @map("sub_criteria_id")
  formSubmissionId String?      @map("form_submission_id") @db.Uuid
  originalFilename String       @map("original_filename") @db.VarChar(500)
  storedFilename   String       @unique @map("stored_filename") @db.VarChar(255)
  filePath         String       @map("file_path") @db.VarChar(1000)
  fileType         String       @map("file_type") @db.VarChar(20)
  fileSize         Int          @map("file_size")
  uploadStatus     UploadStatus @default(pending) @map("upload_status")
  uploadedAt       DateTime     @default(now()) @map("uploaded_at") @db.Timestamptz

  // Relations
  teacher        User            @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subCriterion   SubCriterion    @relation(fields: [subCriteriaId], references: [id], onDelete: Cascade)
  formSubmission FormSubmission? @relation(fields: [formSubmissionId], references: [id], onDelete: SetNull)

  @@index([teacherId], map: "idx_doc_teacher")
  @@index([subCriteriaId], map: "idx_doc_sub_criteria")
  @@index([formSubmissionId], map: "idx_doc_form_submission")
  @@index([uploadStatus], map: "idx_doc_upload_status")
  @@index([uploadedAt], map: "idx_doc_uploaded_at")
  @@map("uploaded_documents")
}

/// Audit trail for all significant user actions.
model ActivityLog {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  action      String   @db.VarChar(100) // e.g. 'UPLOADED_FILE', 'SUBMITTED_FORM'
  targetType  String?  @map("target_type") @db.VarChar(50)
  targetId    String?  @map("target_id") @db.Uuid
  description String?  @db.Text
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_log_user_id")
  @@index([action], map: "idx_log_action")
  @@index([targetType, targetId], map: "idx_log_target")
  @@index([createdAt], map: "idx_log_created_at")
  @@map("activity_logs")
}

/// In-app notifications sent between users or by the system.
model Notification {
  id          String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  recipientId String           @map("recipient_id") @db.Uuid
  senderId    String?          @map("sender_id") @db.Uuid
  message     String           @db.Text
  type        NotificationType @default(reminder)
  isRead      Boolean          @default(false) @map("is_read")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  recipient User  @relation("NotifRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  sender    User? @relation("NotifSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([recipientId], map: "idx_notif_recipient")
  @@index([senderId], map: "idx_notif_sender")
  @@index([type], map: "idx_notif_type")
  @@index([createdAt], map: "idx_notif_created_at")
  @@map("notifications")
}
