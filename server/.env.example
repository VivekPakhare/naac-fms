# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://username:password@localhost:5432/naac_db

# ---- JWT Authentication ----
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- Client ----
CLIENT_URL=http://localhost:5173

# ---- File Uploads ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
